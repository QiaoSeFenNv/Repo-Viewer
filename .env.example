# Free providers: google-free, mymemory-free.
# AI providers remain available: openai-compatible, generic.
TRANSLATE_PROVIDER=google-free
TRANSLATE_ENDPOINT=
TRANSLATE_MODEL=
TRANSLATE_API_KEY=

# Translation diagnostics are enabled by default. Set to 0 to silence logs.
TRANSLATE_LOG=1

# Optional explicit proxy. On Windows, the system proxy is detected automatically.
# HTTPS_PROXY=http://127.0.0.1:7897
